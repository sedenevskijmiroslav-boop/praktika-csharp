<Window x:Class="FinanceApp2.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="400" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24*"/>
            <RowDefinition Height="131*"/>
            <RowDefinition Height="0*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📝 Регистрация" FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20" Width="156"/>

        <TextBlock Grid.Row="1" Text="Логин:" FontWeight="Bold" Margin="0,5,0,5"/>
        <TextBox x:Name="txtUsername" Grid.Row="2" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="3" Text="Пароль:" FontWeight="Bold" Margin="0,5,0,5"/>
        <PasswordBox x:Name="txtPassword" Grid.Row="3" Margin="0,25,0,15" Grid.RowSpan="2"/>

        <TextBlock Grid.Row="5" Text="Роль:" FontWeight="Bold" Margin="0,5,0,5"/>
        <ComboBox x:Name="cmbRole" Grid.Row="5" Margin="0,25,0,1" Grid.RowSpan="2">
            <ComboBoxItem Content="User" IsSelected="True"/>
            <ComboBoxItem Content="Admin"/>
        </ComboBox>

        <TextBlock x:Name="txtError" Grid.Row="8" Foreground="Red" TextAlignment="Center" Margin="0,13,0,-13"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Left" Margin="47,17,0,0" Width="243" Grid.RowSpan="2">
            <Button Content="Зарегистрироваться" Width="150" Height="35" Margin="5" Click="Register_Click" Background="#27AE60" Foreground="White"/>
            <Button Content="Отмена" Width="80" Height="35" Click="Cancel_Click" Background="#95A5A6" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>