<Window x:Class="FinanceApp2.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="350" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📊 Финансовый учет" FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Логин:" FontWeight="Bold" Margin="0,5"/>
        <TextBox x:Name="txtUsername" Grid.Row="2" Margin="0,0,0,15" Height="30"/>

        <TextBlock Grid.Row="3" Text="Пароль:" FontWeight="Bold" Margin="0,5"/>
        <PasswordBox x:Name="txtPassword" Grid.Row="4" Margin="0,0,0,15" Height="30"/>

        <TextBlock x:Name="txtError" Grid.Row="5" Foreground="Red" TextAlignment="Center" Margin="0,5"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Войти" Width="100" Height="35" Margin="5" Click="Login_Click" Background="#27AE60" Foreground="White"/>
            <Button Content="Регистрация" Width="100" Height="35" Margin="5" Click="Register_Click" Background="#3498DB" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>