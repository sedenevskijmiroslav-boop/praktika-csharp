<Window x:Class="FinanceApp2.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="400" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📝 Регистрация" FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Логин:" FontWeight="Bold" Margin="0,5"/>
        <TextBox x:Name="txtUsername" Grid.Row="2" Margin="0,0,0,15" Height="30"/>

        <TextBlock Grid.Row="3" Text="Пароль:" FontWeight="Bold" Margin="0,5"/>
        <PasswordBox x:Name="txtPassword" Grid.Row="4" Margin="0,0,0,15" Height="30"/>

        <TextBlock Grid.Row="5" Text="Роль:" FontWeight="Bold" Margin="0,5"/>
        <ComboBox x:Name="cmbRole" Grid.Row="6" Margin="0,0,0,15" Height="30">
            <ComboBoxItem Content="User" IsSelected="True"/>
            <ComboBoxItem Content="Admin"/>
        </ComboBox>

        <TextBlock x:Name="txtError" Grid.Row="7" Foreground="Red" TextAlignment="Center" Margin="0,5"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Зарегистрироваться" Width="150" Height="35" Margin="5" Click="Register_Click" Background="#27AE60" Foreground="White"/>
            <Button Content="Отмена" Width="80" Height="35" Margin="5" Click="Cancel_Click" Background="#95A5A6" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>