<Window x:Class="FinanceApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FinanceApp2.ViewModels"
        xmlns:conv="clr-namespace:FinanceApp2.Converters"
        Title="Учет финансов" Height="700" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:BalanceConverter x:Key="BalanceConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <DataTemplate x:Key="TransactionTemplate">
            <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding Date, StringFormat=dd.MM.yyyy}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Type}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Type}" Value="Доход">
                                        <Setter Property="Foreground" Value="Green"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Type}" Value="Расход">
                                        <Setter Property="Foreground" Value="Red"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBox Grid.Column="2" Text="{Binding Amount, StringFormat=C, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" 
                             Width="90" HorizontalAlignment="Left"/>
                    <TextBlock Grid.Column="3" Text="{Binding Description}" Margin="10,0,0,0"/>
                </Grid>
            </Border>
        </DataTemplate>

        <ControlTemplate x:Key="AddButtonTemplate" TargetType="Button">
            <Border Background="{TemplateBinding Background}" 
                    CornerRadius="10" 
                    BorderBrush="DarkGreen" 
                    BorderThickness="2"
                    Padding="15,5">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="LightGreen"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="DarkGreen"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="_Файл">
                <MenuItem Header="Выход" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Транзакции">
                <MenuItem Header="Добавить" Command="{Binding AddTransactionCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="Редактировать" Command="{Binding EditTransactionCommand}" InputGestureText="Ctrl+E"/>
                <MenuItem Header="Удалить" Command="{Binding DeleteTransactionCommand}" InputGestureText="Del"/>
            </MenuItem>
            <MenuItem Header="_Отчёты">
                <MenuItem Header="Общий отчет" Click="Report_Click"/>
            </MenuItem>
            <MenuItem Header="_Настройки">
                <MenuItem Header="О программе" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <ToolBar Grid.Row="1">
            <Button Content="🔄 Загрузить из API" 
                    Command="{Binding LoadDataCommand}"
                    Background="LightBlue"
                    Padding="10,5"/>
            <Separator/>
            <Button Content="➕ Добавить транзакцию" 
                    Command="{Binding AddTransactionCommand}" 
                    Template="{StaticResource AddButtonTemplate}"
                    Background="LightGreen"/>
            <Separator/>
            <Button Content="✏ Редактировать" Command="{Binding EditTransactionCommand}" ToolTip="Ctrl+E"/>
            <Button Content="❌ Удалить" Command="{Binding DeleteTransactionCommand}" ToolTip="Del"/>
        </ToolBar>

        <Border Grid.Row="2" Background="#F0F0F0" Padding="10" Margin="0,5">
            <StackPanel Orientation="Horizontal">
                <Label Content="Фильтр по дате:" VerticalAlignment="Center"/>
                <DatePicker SelectedDate="{Binding FilterDate}" Width="120" VerticalAlignment="Center"/>
                <Button Content="Сбросить" Command="{Binding ClearFilterCommand}" Margin="10,0" Width="70" VerticalAlignment="Center"/>

                <Separator Width="20" Visibility="Hidden"/>

                <Border Background="LightGray" CornerRadius="5" Padding="10" Margin="20,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Баланс: " FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Balance, StringFormat=C, Mode=OneWay}" 
                                   FontWeight="Bold" FontSize="16" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Balance}" Value="0">
                                            <Setter Property="Foreground" Value="Black"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Balance, Converter={StaticResource BalanceConverter}}" 
                                                     Value="Positive">
                                            <Setter Property="Foreground" Value="Green"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <ListBox Grid.Row="3" 
                 ItemsSource="{Binding Transactions}" 
                 SelectedItem="{Binding SelectedTransaction, Mode=TwoWay}"
                 ItemTemplate="{StaticResource TransactionTemplate}"
                 Margin="10"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
            <Button x:Name="BtnShowChat" Content="💬 Чат" Width="100" Height="35" Margin="5" Click="ToggleChat_Click" Background="#3498DB" Foreground="White" FontWeight="Bold"/>
            <Button x:Name="BtnShowReminders" Content="⏰ Напоминания" Width="130" Height="35" Margin="5" Click="ToggleReminders_Click" Background="#3498DB" Foreground="White" FontWeight="Bold"/>
        </StackPanel>

        <Border x:Name="ChatPanel" Grid.Row="5" Background="#F9F9F9" CornerRadius="5" Padding="10" Margin="10,0,10,10" Height="250" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="💬 Чат" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

                <ListBox Grid.Row="1" x:Name="ChatListBox">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="5" BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
                                <StackPanel>
                                    <TextBlock Text="{Binding FromUser}" FontWeight="Bold" FontSize="12" Foreground="#2C3E50"/>
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Margin="0,5,0,5"/>
                                    <TextBlock Text="{Binding Timestamp, StringFormat=dd.MM.yyyy HH:mm}" FontSize="10" Foreground="Gray"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBox x:Name="ChatMessageBox" Height="35" Width="120" Margin="0,0,5,0" VerticalContentAlignment="Center"/>
                    <Button Content="📤 Отправить" Width="90" Height="35" Click="SendMessage_Click" Background="#3498DB" Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="RemindersPanel" Grid.Row="5" Background="#F9F9F9" CornerRadius="5" Padding="10" Margin="10,0,10,10" Height="350" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="5" Padding="10" Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="📋 Список напоминаний" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ReminderListBox">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,5" BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14"/>
                                                    <TextBlock Text="{Binding Amount, StringFormat=C}" FontSize="14" Foreground="Red" Margin="0,5,0,0"/>
                                                    <TextBlock Text="До: " FontSize="12" Margin="0,5,0,0"/>
                                                    <TextBlock Text="{Binding DueDate, StringFormat=dd.MM.yyyy}" FontSize="12" Margin="15,0,0,0"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button Content="✓ Оплачено" Width="80" Margin="5" Tag="{Binding}" Click="MarkReminderPaid_Click" Background="#27AE60" Foreground="White"/>
                                                    <Button Content="✗ Удалить" Width="70" Margin="5" Tag="{Binding}" Click="DeleteReminder_Click" Background="#E74C3C" Foreground="White"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="5" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="➕ Новое напоминание" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

                        <TextBlock Grid.Row="1" Text="Название:" Margin="0,5" FontWeight="Bold"/>
                        <TextBox x:Name="ReminderTitleBox" Grid.Row="2" Height="35" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

                        <TextBlock Grid.Row="3" Text="Сумма:" Margin="0,5" FontWeight="Bold"/>
                        <TextBox x:Name="ReminderAmountBox" Grid.Row="4" Height="35" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

                        <TextBlock Grid.Row="5" Text="Дата платежа:" Margin="0,5" FontWeight="Bold"/>
                        <DatePicker x:Name="ReminderDatePicker" Grid.Row="6" Height="85" Margin="0,0,0,15"/>

                        <Button Grid.Row="7" Content="➕ Добавить напоминание" Height="40" Margin="0,10,0,0" Click="AddReminder_Click" Background="#3498DB" Foreground="White" FontWeight="Bold" FontSize="14"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.RowSpan="6" Background="#CC000000" 
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
              IsHitTestVisible="{Binding IsLoading}">
            <Border Background="#333333" VerticalAlignment="Center" HorizontalAlignment="Center" 
                    CornerRadius="10" Padding="30">
                <StackPanel>
                    <TextBlock Text="⏳" FontSize="48" TextAlignment="Center"/>
                    <TextBlock Text="{Binding LoadingMessage}" FontSize="16" Foreground="White" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>