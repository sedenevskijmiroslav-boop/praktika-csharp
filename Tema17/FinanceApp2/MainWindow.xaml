<Window x:Class="FinanceApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:FinanceApp2.Converters"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="Учет финансов" Height="850" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{Binding BackgroundBrush}">

    <Window.Resources>
        <conv:BalanceConverter x:Key="BalanceConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <DataTemplate x:Key="TransactionTemplate">
            <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding Date, StringFormat=dd.MM.yyyy}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Type}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Type}" Value="Доход">
                                        <Setter Property="Foreground" Value="Green"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Type}" Value="Расход">
                                        <Setter Property="Foreground" Value="Red"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBox Grid.Column="2" Text="{Binding Amount, StringFormat=C, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" 
                             Width="90" HorizontalAlignment="Left"/>
                    <TextBlock Grid.Column="3" Text="{Binding Description}" Margin="10,0,0,0"/>
                </Grid>
            </Border>
        </DataTemplate>

        <ControlTemplate x:Key="AddButtonTemplate" TargetType="Button">
            <Border Background="{TemplateBinding Background}" 
                    BorderBrush="DarkGreen" 
                    BorderThickness="2"
                    Padding="15,5">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="LightGreen"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="DarkGreen"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="_Файл">
                <MenuItem Header="Выход" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Транзакции">
                <MenuItem Header="Добавить" Command="{Binding AddTransactionCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="Редактировать" Command="{Binding EditTransactionCommand}" InputGestureText="Ctrl+E"/>
                <MenuItem Header="Удалить" Command="{Binding DeleteTransactionCommand}" InputGestureText="Del"/>
            </MenuItem>
            <MenuItem Header="_Отчёты">
                <MenuItem Header="Общий отчет" Click="Report_Click"/>
            </MenuItem>
            <MenuItem Header="_Настройки">
                <MenuItem Header="О программе" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <ToolBar Grid.Row="1">
            <Button Content="🔄 Загрузить из API" 
                    Command="{Binding LoadDataCommand}"
                    Background="LightBlue"
                    Padding="10,5"/>
            <Separator/>
            <Button Content="➕ Добавить транзакцию" 
                    Command="{Binding AddTransactionCommand}" 
                    Template="{StaticResource AddButtonTemplate}"
                    Background="LightGreen"/>
            <Separator/>
            <Button Content="✏ Редактировать" Command="{Binding EditTransactionCommand}" ToolTip="Ctrl+E"/>
            <Button Content="❌ Удалить" Command="{Binding DeleteTransactionCommand}" ToolTip="Del"/>
        </ToolBar>

        <Border Grid.Row="2" Background="#F0F0F0" Padding="10" Margin="10,5,10,5">
            <StackPanel Orientation="Horizontal">
                <Label Content="Фильтр по дате:" VerticalAlignment="Center"/>
                <DatePicker SelectedDate="{Binding FilterDate}" Width="120" VerticalAlignment="Center"/>
                <Button Content="Сбросить" Command="{Binding ClearFilterCommand}" Margin="10,0" Width="70" VerticalAlignment="Center"/>

                <Separator Width="20" Visibility="Hidden"/>

                <Border Background="LightGray" Padding="10" Margin="20,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Баланс: " FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Balance, StringFormat=C, Mode=OneWay}" 
                                   FontWeight="Bold" FontSize="16" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Balance}" Value="0">
                                            <Setter Property="Foreground" Value="Black"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Balance, Converter={StaticResource BalanceConverter}}" 
                                                     Value="Positive">
                                            <Setter Property="Foreground" Value="Green"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Background="#E8F4FD" Padding="10" Margin="10,5,10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="◀" Width="45" Height="45" 
                        Command="{Binding PreviousMonthCommand}"
                        FontSize="22" FontWeight="Bold"
                        Background="#3498DB" Foreground="White"/>

                <TextBlock Grid.Column="1" Text="{Binding SelectedMonth, StringFormat=MMMM yyyy}" 
                           FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <Button Grid.Column="2" Content="▶" Width="45" Height="45" 
                        Command="{Binding NextMonthCommand}"
                        FontSize="22" FontWeight="Bold"
                        Background="#3498DB" Foreground="White"/>
            </Grid>
        </Border>

        <Border Grid.Row="4" Background="#FFF3E0" Padding="10" Margin="10,5,10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="💰 Лимит бюджета на месяц:" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding BudgetLimit, StringFormat=C, UpdateSourceTrigger=PropertyChanged}" 
                         Width="130" Height="35" Margin="15,0" TextAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                <TextBlock Grid.Column="3" Text="⚡" FontSize="18" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="5" Background="White" Padding="10" Margin="10,5,10,5" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="📈 Доходы" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="Green"/>
                <lvc:CartesianChart Grid.Row="1" Grid.Column="0" Series="{Binding IncomeChartSeries}">
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Title="Сумма (₽)" FontSize="11"/>
                    </lvc:CartesianChart.AxisY>
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Title="Дни месяца" FontSize="11"/>
                    </lvc:CartesianChart.AxisX>
                </lvc:CartesianChart>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="📉 Расходы" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="Red"/>
                <lvc:CartesianChart Grid.Row="1" Grid.Column="2" Series="{Binding ExpenseChartSeries}">
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Title="Сумма (₽)" FontSize="11"/>
                    </lvc:CartesianChart.AxisY>
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Title="Дни месяца" FontSize="11"/>
                    </lvc:CartesianChart.AxisX>
                </lvc:CartesianChart>
            </Grid>
        </Border>

        <ListBox Grid.Row="6" 
                 ItemsSource="{Binding Transactions}" 
                 SelectedItem="{Binding SelectedTransaction, Mode=TwoWay}"
                 ItemTemplate="{StaticResource TransactionTemplate}"
                 Margin="10,5"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
            <Button x:Name="BtnShowChat" Content="💬 Чат" Width="110" Height="35" Margin="5" Click="ToggleChat_Click" Background="#3498DB" Foreground="White" FontWeight="Bold" FontSize="14"/>
            <Button x:Name="BtnShowReminders" Content="⏰ Напоминания" Width="140" Height="35" Margin="5" Click="ToggleReminders_Click" Background="#3498DB" Foreground="White" FontWeight="Bold" FontSize="14"/>
        </StackPanel>

        <Border x:Name="ChatPanel" Grid.Row="8" Background="#F9F9F9" Padding="10" Margin="10,0,10,10" Height="220" Visibility="Collapsed" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="💬 Чат" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>

                <ListBox Grid.Row="1" x:Name="ChatListBox">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="3" BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
                                <StackPanel>
                                    <TextBlock Text="{Binding FromUser}" FontWeight="Bold" FontSize="11" Foreground="#2C3E50"/>
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Margin="0,3,0,3"/>
                                    <TextBlock Text="{Binding Timestamp, StringFormat=dd.MM.yyyy HH:mm}" FontSize="9" Foreground="Gray"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBox x:Name="ChatMessageBox" Height="35" Width="80" Margin="0,0,8,0" VerticalContentAlignment="Center" FontSize="12"/>
                    <Button Content="📤 Отправить" Width="90" Height="35" Click="SendMessage_Click" Background="#3498DB" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="RemindersPanel" Grid.Row="8" Background="#F9F9F9" Padding="8" Margin="10,0,10,10" Height="280" Visibility="Collapsed" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="240"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" Padding="6" Margin="0,0,6,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="📋 Список напоминаний" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ReminderListBox">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,3" BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="12"/>
                                                    <TextBlock Text="{Binding Amount, StringFormat=C}" FontSize="12" Foreground="Red"/>
                                                    <TextBlock Text="{Binding DueDate, StringFormat=dd.MM.yyyy}" FontSize="10" Foreground="Gray"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button Content="✓" Width="35" Margin="2" Tag="{Binding}" Click="MarkReminderPaid_Click" Background="#27AE60" Foreground="White"/>
                                                    <Button Content="✗" Width="35" Margin="2" Tag="{Binding}" Click="DeleteReminder_Click" Background="#E74C3C" Foreground="White"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="White" Padding="6">
                    <StackPanel>
                        <TextBlock Text="➕ Новое напоминание" FontWeight="Bold" FontSize="12" Margin="0,0,0,8"/>

                        <TextBlock Text="Название:" Margin="0,3" FontSize="11"/>
                        <TextBox x:Name="ReminderTitleBox" Height="28" Margin="0,0,0,6"/>

                        <TextBlock Text="Сумма:" Margin="0,3" FontSize="11"/>
                        <TextBox x:Name="ReminderAmountBox" Height="28" Margin="0,0,0,6"/>

                        <TextBlock Text="Дата платежа:" Margin="0,3" FontSize="11"/>
                        <DatePicker x:Name="ReminderDatePicker" Height="28" Margin="0,0,0,8"/>

                        <Button Content="➕ Добавить" Height="32" Margin="0,5,0,0" Click="AddReminder_Click" Background="#3498DB" Foreground="White" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.RowSpan="9" Background="#CC000000" 
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
              IsHitTestVisible="{Binding IsLoading}">
            <Border Background="#333333" VerticalAlignment="Center" HorizontalAlignment="Center" 
                    Padding="40">
                <StackPanel>
                    <TextBlock Text="⏳" FontSize="48" TextAlignment="Center"/>
                    <TextBlock Text="{Binding LoadingMessage}" FontSize="16" Foreground="White" Margin="0,15,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>